{
  "version": 2,
  "functions": {
    "server.js": {
      "memory": 3008,
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ],
  "crons": [
    {
      "path": "/api/monitor-now",
      "schedule": "*/10 * * * *"
    }
  ]
}
