{
  "version": 2,
  "functions": {
    "server.js": {
      "memory": 3008,
      "maxDuration": 60
    }
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/(.*)", "dest": "/server.js" },
    { "src": "/(.*)", "dest": "/server.js" }
  ],
  "crons": [
    {
      "path": "/api/monitor-now",
      "schedule": "*/10 * * * *"
    }
  ]
}
