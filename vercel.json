{
  "version": 2,
  "framework": null,
  "functions": {
    "server.js": {
      "memory": 3008,
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/server.js" },
    { "source": "/(.*)", "destination": "/public/$1" }
  ],
  "crons": [
    {
      "path": "/api/monitor-now",
      "schedule": "*/10 * * * *"
    }
  ]
}
